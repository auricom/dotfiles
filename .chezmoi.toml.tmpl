{{- /* Checks if running interactively */ -}}
{{- $interactive := stdinIsATTY -}}

{{- /* Auto-detect form factor: laptops via DMI chassis type, workstation/server via prompt */ -}}
{{- /* Laptop/portable types: 8=Portable 9=Laptop 10=Notebook 11=Handheld 14=SubNotebook 30=Tablet 31=Convertible 32=Detachable */ -}}
{{- $chassisType := output "sh" "-c" "cat /sys/class/dmi/id/chassis_type 2>/dev/null || echo 3" | trim -}}
{{- $laptopTypes := list "8" "9" "10" "11" "14" "30" "31" "32" -}}
{{- $formFactor := "workstation" -}}
{{- if has $chassisType $laptopTypes -}}
{{-   $formFactor = "laptop" -}}
{{- else if $interactive -}}
{{-   $formFactor = promptStringOnce . "formFactor" "formFactor (workstation/server)" -}}
{{- end -}}
{{- $brightnessDeviceName := output "sh" "-c" "command -v ddcutil >/dev/null 2>&1 && ddcutil detect 2>/dev/null | grep 'I2C bus:' | grep -o 'i2c-[0-9]*' | head -1 | sed 's/^/ddc:/' || true" | trim -}}

{{- if $interactive -}}
{{-   writeToStdout "💡 Tip: you can re-enter your data with `chezmoi init --data=false`.\n" -}}
{{- end -}}
encryption = "age"
[age]
  identity = "{{ .chezmoi.homeDir }}/.config/sops/age/chezmoi.txt"
  recipient = "age19kk2hhldesux98t50r9wmdhdvj7xw29205gy58tj70m53p5dweksv70uh9"

[data]
  formFactor = "{{ $formFactor }}"
  brightnessDeviceName = "{{ $brightnessDeviceName }}"
