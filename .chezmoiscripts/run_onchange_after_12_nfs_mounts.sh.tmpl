{{- if ne .formFactor "server" -}}
#!/usr/bin/env bash

# NFS mounts configuration script
# Configures NFS mounts as systemd system mount units
# Data hash: {{ include ".chezmoidata/nfs.yaml" | sha256sum }}

set -euo pipefail

# Source utility functions
source "{{ .chezmoi.homeDir }}/.local/lib/chezmoi_utils.sh"

NFS_SERVER_IP="{{ .nfs.server_ip }}"
SHARE_PREFIX="{{ .nfs.share_prefix }}"
MOUNTPOINT_PREFIX="{{ .nfs.mountpoint_prefix }}"
NFS_OPTS="{{ .nfs.options | replace ",x-systemd.automount" "" }}"
UNIT_DIR="/etc/systemd/system"
_needs_reload=false

install_mount_unit() {
    local share="$1"
    local mount_point="$2"

    local unit_name
    unit_name=$(systemd-escape --path "$mount_point")

    local mount_unit="${UNIT_DIR}/${unit_name}.mount"

    local mount_content="[Unit]
Description=NFS Mount ${mount_point}
Requires=network-online.target
After=network-online.target

[Mount]
What=${share}
Where=${mount_point}
Type=nfs
Options=${NFS_OPTS}

[Install]
WantedBy=multi-user.target"

    sudo mkdir -p "${mount_point}"

    local existing=""
    [[ -f "$mount_unit" ]] && existing=$(cat "$mount_unit")
    if [[ "$existing" != "$mount_content" ]]; then
        log_info "Writing mount unit: ${unit_name}.mount"
        echo "$mount_content" | sudo tee "$mount_unit" >/dev/null
        _needs_reload=true
    else
        log_info "Mount unit already up to date: ${unit_name}.mount"
    fi
}

reload_systemd_if_needed() {
    if [[ "$_needs_reload" != true ]]; then
        return
    fi

    log_info "Reloading systemd daemon"
    sudo systemctl daemon-reload
    _needs_reload=false
}

activate_mount_unit() {
    local mount_point="$1"

    local unit_name
    unit_name=$(systemd-escape --path "$mount_point")

    systemd_system_enable_start "${unit_name}.mount"
}

main() {
    log_section "Configuring NFS mounts"

{{- range .nfs.mounts }}
    install_mount_unit \
        "${NFS_SERVER_IP}:${SHARE_PREFIX}/{{ .share }}" \
        "${MOUNTPOINT_PREFIX}/{{ .mountpoint }}"
{{- end }}

    reload_systemd_if_needed

{{- range .nfs.mounts }}
    activate_mount_unit \
        "${MOUNTPOINT_PREFIX}/{{ .mountpoint }}"
{{- end }}

    log_info "NFS mounts configuration completed"
}

# Run main function
main "$@"
{{- end -}}
